-- message Achievement {
--   required int32 id = 1;
--   required bool unlocked = 2;
--   optional int32 steps = 3;
-- }
--
-- Struct layout (fields relative to the element's own base — for
-- repeated fields, that's the element pointer itself, offset 0):

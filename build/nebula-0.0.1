    -- of the 6-dword budget alongside the character bytes.
    if byteCount + 1 <= INLINE_MAX_BYTES then
        return writeInline(ptr, nameBytes, byteCount)
    end

    return writeLong(ptr, nameBytes, byteCount)
end


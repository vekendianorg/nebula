    if type(value) ~= "string" then
        return false
    end

    local ptr, err = Memory.deref(baseAddress, field.offset)
    if not ptr then
        return false
    end

    local nameBytes = {}
    local byteCount = 0

    for _, code in utf8.codes(value) do
        local encoded = utf8.char(code)
        local bytes = { encoded:byte(1, -1) }
